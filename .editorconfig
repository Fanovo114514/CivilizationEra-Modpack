# ============================================================
# 编辑器配置 - 统一代码风格（效仿 Create / Tinkers' Construct）
# ============================================================

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_size = 4
max_line_length = 120
ij_java_continuation_indent_size = 8
ij_java_imports_layout = *,|,java.**,javax.**,|,com.civilizationera.**
ij_java_class_count_to_use_import_on_demand = 999
ij_java_names_count_to_use_import_on_demand = 999

[*.{gradle,gradle.kts}]
indent_size = 4

[*.{json,json5}]
indent_size = 2

[*.{js,ts}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{xml,html}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.properties]
indent_size = 4
